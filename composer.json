{
  "name": "solophp/event-dispatcher",
  "description": "Minimal, PSR-14 compatible event dispatcher with priorities and stoppable propagation.",
  "type": "library",
  "license": "MIT",
  "keywords": ["event dispatcher", "psr-14", "event listener", "event", "dispatcher"],
  "autoload": {
    "psr-4": {
      "Solo\\EventDispatcher\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "require": {
    "php": "^8.3",
    "psr/event-dispatcher": "^1.0",
    "psr/log": "^3.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^12.3",
    "phpstan/phpstan": "^2.1",
    "squizlabs/php_codesniffer": "^3.13"
  },
  "scripts": {
    "cs-check": "phpcs --standard=PSR12 src/",
    "cs-fix": "phpcbf --standard=PSR12 src/",
    "analyze": "phpstan analyze",
    "test": [
      "@cs-check",
      "@analyze",
      "phpunit"
    ]
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
